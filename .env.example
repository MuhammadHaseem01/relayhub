# ── Required ──────────────────────────────────────────────────────────────────

# Resend API Key for Email provider (https://resend.com/api-keys)
RESEND_API_KEY="re_123456789"
FROM_EMAIL="onboarding@resend.dev"

# PostgreSQL connection string
# When running locally via docker-compose, use the value below as-is.
# For external Postgres, replace with your actual DSN.
DATABASE_URL=postgres://relayhub:relayhub_secret@localhost:5432/relayhub?sslmode=disable

# ── Optional ──────────────────────────────────────────────────────────────────

# Discord Webhook URL — used as the default when no recipient is passed in the request.
# To get one: Discord Server Settings → Integrations → Webhooks → New Webhook → Copy URL
# Looks like: https://discord.com/api/webhooks/123456789/abcdef...
DISCORD_WEBHOOK_URL=""

# HTTP port for the API server (default: 8080)
PORT=8080
