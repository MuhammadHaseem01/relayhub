Table users {
  id int [primary key]
  name varchar [not null]
  email varchar
  phone varchar [not null]
  user_type users.type
  vehicle_type delivery_rider.vehicle_type
  security_fee_paid boolean
  security_fee_amount int
  cnic varchar [null]
  is_active bool [not null]
  business_id int [ref: > business.id, null]
  created_at datetime [not null]
  updated_at datetime
  is_deleted bool
}

Table otp {
  id int [primary key]
  code varchar [not null]
  user_id int [ref: > users.id]
  created_at datetime
  expiry datetime [not null]
}

Enum users.type {
  admin
  individual
  business
  rider
}

Enum delivery_rider.vehicle_type {
  motorbike
  bicycle
  van
}

Table delivery {
  id int [primary key]
  sender_id int [ref: > users.id, not null]
  receiver_id int [ref: > users.id, not null]
  rider_id int [ref: > users.id]
  delivery_type delivery.type
  delivery_status delivery.status
  system_generated_amount decimal
  delivery_charges decimal [not null]
  extra_cod_charges decimal
  is_online_payment bool [not null]
  rider_invested_amount decimal
  otp_code varchar [not null]
  pickup_address varchar [not null]
  pickup_location varchar 
  delivery_address varchar [not null]
  delivery_location varchar
  payment_status delivery.payment_status [not null]
  created_at datetime [not null]
  updated_at datetime
}
Enum delivery.type {
  individual
  business
}

Enum delivery.status {
  pending
  in_progress
  completed
  failed
}

Enum delivery.payment_status {
  paid
  unpaid
}

Table business {
  id int [primary key]
  name varchar
  address varchar [not null]
  created_at datetime
  updated_at datetime
}

Table business_api_token {
  id int [primary key]
  owner int [ref: > business.id, not null]
  active boolean
  created_at datetime
}

Table business_license {
  id int [primary key]
  owner int [ref: > business.id, not null]
  booking_limit_per_instance int [not null]
  expire_date datetime
}

Table delivery_dispute {
  id int [primary key]
  delivery_id int [ref: > delivery.id]
  raised_by dispute.raised_by_type
  dispute_reason varchar
  dispute_status dispute.status
  support int [ref: - users.id]
  created_at datetime
  updated_at datetime
}

Enum dispute.raised_by_type {
  individual
  rider
  business
}

Enum dispute.status {
  open
  resolved
  closed
}

Table vehicle {
  id int [primary key]
  rider_id int [ref: > users.id]
  vehicle_type vehicle.type
  vehicle_registration varchar
  is_license_required bool
  license_details varchar
  created_at datetime
  updated_at datetime
}

Enum vehicle.type {
  motorbike
  bicycle
  van
}
